# Required for LLM-driven scenarios
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional overrides
GOOGLE_CLOUD_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# Local blockchain server defaults
BLOCKCHAIN_HOST=127.0.0.1
BLOCKCHAIN_PORT=8000
BLOCKCHAIN_URL=http://127.0.0.1:8000

# Agent logging
VERBOSE_AGENT_LOGS=0
